{
  "name": "spotmap-frontend",
  "version": "1.0.0",
  "description": "SpotMap - Frontend tests con Jest",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:verbose": "node --experimental-vm-modules node_modules/jest/bin/jest.js --verbose",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:mobile": "playwright test --project=mobile-chromium",
    "e2e:desktop": "playwright test --project=desktop-chromium",
    "e2e:flow": "playwright test --grep @auth-flow",
    "e2e:seed": "node e2e/seed-users.mjs",
    "e2e:cleanup": "node e2e/cleanup-test-data.mjs",
    "e2e:install": "playwright install chromium",
    "obfuscate": "node obfuscate.cjs",
    "build": "node build-production.cjs",
    "build:secure": "npm run obfuscate && npm run build"
  },
  "keywords": [
    "testing",
    "jest",
    "frontend",
    "spotmap"
  ],
  "author": "SpotMap Team",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.58.2",
    "http-server": "^14.1.1",
    "javascript-obfuscator": "^5.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  }
}
